rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() { return request.auth != null; }
    function userRole() { return request.auth.token.role; }
    function isSuperAdmin() { return userRole() == 'superadmin'; }
    function isPresidente() { return userRole() == 'presidente'; }
    function isAdminLevel() { return isSuperAdmin() || isPresidente(); }

    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.auth.uid == userId;
      allow update: if isAdminLevel();
      allow delete: if false;
    }
    match /rooms/{roomId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdminLevel();
    }
    match /clients/{clientId} {
      allow read, create, update: if isLoggedIn();
      allow delete: if isAdminLevel();
    }
    match /appointments/{appointmentId} {
      allow read, create: if isLoggedIn();
      allow update: if isAdminLevel() || resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
    match /logs/{logId} {
      allow read: if isAdminLevel();
      allow create: if isLoggedIn();
      allow update, delete: if false;
    }
  }
}
